# Production Environment Configuration
# Copy this to /opt/mustafacli/.env on production server

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Model Settings
AGENT_MODEL_NAME=qwen2.5-coder:32b
AGENT_TEMPERATURE=0.0
AGENT_MAX_TOKENS=8192
AGENT_MAX_ITERATIONS=100

# Working Directory (IMPORTANT: Use absolute path in production)
AGENT_WORKING_DIR=/opt/mustafacli/workspace

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Command Execution (Keep false in production!)
AGENT_ALLOW_DANGEROUS_COMMANDS=false

# Tool Timeouts
AGENT_TOOL_TIMEOUT=300
AGENT_BASH_TIMEOUT=120

# ============================================================================
# LOGGING
# ============================================================================

AGENT_LOG_LEVEL=INFO
AGENT_LOG_FILE=/var/log/mustafacli/agent.log
AGENT_JSON_LOGS=true  # JSON format for production log aggregation

# ============================================================================
# OBSERVABILITY
# ============================================================================

# Metrics
AGENT_ENABLE_METRICS=true
AGENT_METRICS_PORT=8000

# ============================================================================
# PROVIDER CONFIGURATION
# ============================================================================

PROVIDER_TYPE=ollama
PROVIDER_OLLAMA_URL=http://localhost:11434
PROVIDER_HTTP_TIMEOUT=300
PROVIDER_MAX_RETRIES=3

# ============================================================================
# CONTEXT MANAGEMENT
# ============================================================================

AGENT_MAX_CONTEXT_TOKENS=32000
AGENT_CONTEXT_RESERVE_TOKENS=4000
AGENT_COMPACTION_THRESHOLD=0.8
AGENT_KEEP_RECENT_MESSAGES=10

# ============================================================================
# PERFORMANCE
# ============================================================================

AGENT_ENABLE_PARALLEL_TOOLS=true
AGENT_ENABLE_CACHING=true

# ============================================================================
# API KEYS (Use secrets manager in production!)
# ============================================================================

# Uncomment if using Anthropic Claude:
# ANTHROPIC_API_KEY=your_api_key_here

# Uncomment if using OpenAI:
# OPENAI_API_KEY=your_api_key_here
