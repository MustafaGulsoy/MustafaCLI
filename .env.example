# Agent Configuration
AGENT_MODEL_NAME=qwen2.5-coder:32b
AGENT_TEMPERATURE=0.0
AGENT_MAX_ITERATIONS=100
AGENT_MAX_TOKENS=8192
AGENT_WORKING_DIR=.
AGENT_LOG_LEVEL=INFO
AGENT_LOG_FILE=agent.log
AGENT_ENABLE_METRICS=true
AGENT_METRICS_PORT=8000

# Provider Configuration
PROVIDER_TYPE=ollama
PROVIDER_OLLAMA_URL=http://localhost:11434
PROVIDER_OPENAI_URL=http://localhost:1234/v1
PROVIDER_HTTP_TIMEOUT=300
PROVIDER_MAX_RETRIES=3

# API Keys (Never commit these!)
# ANTHROPIC_API_KEY=your_api_key_here
# OPENAI_API_KEY=your_api_key_here

# Tool Configuration
AGENT_TOOL_TIMEOUT=300
AGENT_BASH_TIMEOUT=120
AGENT_ALLOW_DANGEROUS_COMMANDS=false

# Context Management
AGENT_MAX_CONTEXT_TOKENS=32000
AGENT_CONTEXT_RESERVE_TOKENS=4000
AGENT_COMPACTION_THRESHOLD=0.8
AGENT_KEEP_RECENT_MESSAGES=10

# Performance
AGENT_ENABLE_PARALLEL_TOOLS=true
AGENT_ENABLE_CACHING=true
